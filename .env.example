EDINET_API_KEY=your_api_key_here
DATABASE_URL=sqlite:///./data/edinet.db
# 本番ドメイン（SEO canonical・OGP用。未設定時はリクエストURLを使用）
SITE_URL=
# Google Search Console 所有権確認（HTMLタグ方式）
GOOGLE_SITE_VERIFICATION=
# HTMLファイル方式を使う場合（例: google1234abcd.html）
GOOGLE_SITE_VERIFICATION_HTML=
# 本番初回DBシード（Render 等）。GitHub Release の edinet.db.gz URL を指定
DB_BACKUP_URL=
# 本番コンテナ内の収集ログ保存先
COLLECTION_LOG_DIR=/app/data/collection-logs
# 本番コンテナ内 cron（22:00 UTC = 07:00 JST）
ENABLE_DAILY_CRON=true
